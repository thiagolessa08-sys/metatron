# === BACKEND ===

# Java Agent (Sybase IQ proxy via Cloudflare Tunnel)
AGENT_URL=https://<tunnel-url>.trycloudflare.com
AGENT_API_KEY=<sua-api-key>
AGENT_TIMEOUT_SECONDS=30
AGENT_DEFAULT_LIMIT=500
SYBASE_SCHEMA=pref_aruja_sp

# Banco do dashboard (PostgreSQL Railway ou sqlite em dev)
DATABASE_URL=postgresql://user:pass@host:5432/dashboard
# DATABASE_URL=sqlite:///./dev.db   # alternativa dev local

# JWT
JWT_SECRET=<gerar com: openssl rand -hex 32>
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# CORS (separar por vírgula)
CORS_ORIGINS=http://localhost:3000,https://<frontend>.up.railway.app

# === FRONTEND ===

NEXT_PUBLIC_API_URL=http://localhost:8000
